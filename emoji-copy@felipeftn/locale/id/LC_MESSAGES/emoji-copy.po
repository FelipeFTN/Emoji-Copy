msgstr "info penerjemah"

#: emoji-copy@felipeftn/prefs.ui
msgid "Original Owner"
msgstr "Pemilik asli"

#: emoji-copy@felipeftn/prefs.ui
msgid "About"
msgstr "Tentang"

#: emoji-copy@felipeftn/prefs.ui
msgid "List of valid key names"
msgstr "Daftar nama tombol yang valid"

#: emoji-copy@felipeftn/prefs.ui
msgid "Modifier keys must be between chevrons"
msgstr "Tombol pengubah harus diapit tanda kurung siku"

#: emoji-copy@felipeftn/prefs.ui
msgid "Don't use a keyboard shortcut that already exists."
msgstr "Jangan gunakan pintasan keyboard yang sudah ada."

